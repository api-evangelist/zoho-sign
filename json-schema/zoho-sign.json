{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/zoho-sign/main/json-schema/zoho-sign.json",
  "title": "Zoho Sign API Schemas",
  "description": "JSON Schema definitions for Zoho Sign API request and response objects",
  "definitions": {
    "ErrorResponse": {
      "type": "object",
      "title": "Error Response",
      "description": "Standard error response returned by the Zoho Sign API",
      "properties": {
        "status": {
          "type": "string",
          "description": "Status of the response, e.g. 'failure'"
        },
        "code": {
          "type": "string",
          "description": "Error code identifying the type of error"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        }
      }
    },
    "RequestObject": {
      "type": "object",
      "title": "Document Request",
      "description": "A Zoho Sign document request (envelope) for signature collection",
      "properties": {
        "request_id": {
          "type": "string",
          "description": "Unique identifier for the document request"
        },
        "request_name": {
          "type": "string",
          "description": "Name/title of the document request"
        },
        "request_status": {
          "type": "string",
          "description": "Current status of the request",
          "enum": ["draft", "inprogress", "completed", "recalled", "expired", "declined"]
        },
        "owner_id": {
          "type": "string",
          "description": "User ID of the request owner"
        },
        "owner_email": {
          "type": "string",
          "format": "email",
          "description": "Email of the request owner"
        },
        "created_time": {
          "type": "integer",
          "description": "Unix timestamp when the request was created"
        },
        "expiration_days": {
          "type": "integer",
          "description": "Number of days until the request expires"
        },
        "is_sequential": {
          "type": "boolean",
          "description": "Whether signing order is sequential"
        },
        "actions": {
          "type": "array",
          "description": "List of signing actions/recipients",
          "items": {
            "$ref": "#/definitions/ActionObject"
          }
        },
        "document_fields": {
          "type": "array",
          "description": "List of fields in the document",
          "items": {
            "$ref": "#/definitions/FieldObject"
          }
        }
      }
    },
    "ActionObject": {
      "type": "object",
      "title": "Signing Action",
      "description": "Represents a signing action/recipient in a document request",
      "properties": {
        "action_id": {
          "type": "string",
          "description": "Unique identifier for the action"
        },
        "action_type": {
          "type": "string",
          "description": "Type of action",
          "enum": ["SIGN", "VIEW", "APPROVE", "INPERSONSIGN"]
        },
        "recipient_name": {
          "type": "string",
          "description": "Name of the recipient"
        },
        "recipient_email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the recipient"
        },
        "signing_order": {
          "type": "integer",
          "description": "Order in which this recipient should sign"
        },
        "action_status": {
          "type": "string",
          "description": "Current status of this signing action",
          "enum": ["NOTYETSENT", "SENT", "VIEWED", "SIGNED", "APPROVED", "DECLINED"]
        }
      }
    },
    "FieldObject": {
      "type": "object",
      "title": "Document Field",
      "description": "A field within a Zoho Sign document",
      "properties": {
        "field_name": {
          "type": "string",
          "description": "Name identifier for the field"
        },
        "field_type": {
          "type": "string",
          "description": "Type of the field",
          "enum": ["Signature", "Initials", "Date Signed", "Name", "Email", "Company", "Title", "Text", "Checkbox", "Dropdown", "Radio"]
        },
        "field_label": {
          "type": "string",
          "description": "Display label for the field"
        },
        "is_mandatory": {
          "type": "boolean",
          "description": "Whether this field is required"
        },
        "default_value": {
          "type": "string",
          "description": "Default value for the field"
        }
      }
    },
    "TemplateObject": {
      "type": "object",
      "title": "Document Template",
      "description": "A reusable Zoho Sign document template",
      "properties": {
        "template_id": {
          "type": "string",
          "description": "Unique identifier for the template"
        },
        "template_name": {
          "type": "string",
          "description": "Name of the template"
        },
        "description": {
          "type": "string",
          "description": "Description of the template"
        },
        "created_time": {
          "type": "integer",
          "description": "Unix timestamp when the template was created"
        },
        "owner_id": {
          "type": "string",
          "description": "User ID of the template owner"
        },
        "folder_name": {
          "type": "string",
          "description": "Name of the folder containing this template"
        }
      }
    },
    "UserObject": {
      "type": "object",
      "title": "User",
      "description": "A Zoho Sign user account",
      "properties": {
        "user_id": {
          "type": "string",
          "description": "Unique identifier for the user"
        },
        "user_email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the user"
        },
        "user_name": {
          "type": "string",
          "description": "Display name of the user"
        },
        "user_role": {
          "type": "string",
          "description": "Role of the user in the organization",
          "enum": ["ADMIN", "USER", "SENDER"]
        },
        "is_enabled": {
          "type": "boolean",
          "description": "Whether the user account is active"
        }
      }
    }
  }
}
